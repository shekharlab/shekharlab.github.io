---
---
<div class="row">
  {% if site.enable_publication_thumbnails %}
    <div class="col-sm-2 {% if entry.preview %}preview{% else %}abbr{% endif %}">
      {% if entry.preview %}
        {% if entry.preview contains '://' %}
          <img class="preview z-depth-1 rounded" src="{{ entry.preview }}">
        {% else %}
          {% assign entry_path = entry.preview | prepend: '/assets/img/publication_preview/' %}
          {%
            include figure.liquid
            loading="eager"
            path=entry_path
            sizes = "200px"
            class="preview z-depth-1 rounded"
            zoomable=false
            alt=entry.preview
          %}
        {% endif %}
      {% elsif entry.abbr %}
        {% if site.data.venues[entry.abbr] %}
          {% assign venue_style = null %}
          {% if site.data.venues[entry.abbr].color != blank %}
            {% assign venue_style = site.data.venues[entry.abbr].color | prepend: 'style="background-color:' | append: '"' %}
          {% endif %}
          <abbr
            class="badge"
            {% if venue_style %}
              {{ venue_style }}
            {% endif %}
            ><a href="{{site.data.venues[entry.abbr].url}}">{{ entry.abbr }}</a></abbr
          >
        {% else %}
          <abbr class="badge">{{ entry.abbr }}</abbr>
        {% endif %}
      {% endif %}
    </div>
  {% endif %}

  <!-- Entry bib key -->
  <div id="{{entry.key}}" class="{% if site.enable_publication_thumbnails %}col-sm-8{% else %}col-sm-10{% endif %}">
    <!-- Title -->
    <div class="title">
      {% if entry.html %}
        {% if entry.html contains '://' %}
          <a href="{{ entry.html }}">{{ entry.title }}</a>
        {% else %}
          <a href="{{ entry.html | prepend: '/assets/html/' | relative_url }}">{{ entry.title }}</a>
        {% endif %}
      {% else %}
        {{ entry.title }}
      {% endif %}
    </div>
    <!-- Author -->
    <div class="author">
      {% for author in entry.author_array %}
        {%- assign author_last_name = author.last | remove: '¶' | remove: '&' | remove: '*' | remove: '†' | remove: '^' -%}
        {%- assign normalized_first = author.first | replace: '-', ' ' | replace: '.', ' ' -%}
        {%- assign first_parts = normalized_first | split: ' ' -%}
        {%- assign initials = '' -%}
        {%- for part in first_parts -%}
          {%- assign cleaned_part = part | strip -%}
          {%- if cleaned_part != '' -%}
            {%- assign initial = cleaned_part | slice: 0, 1 | upcase -%}
            {%- assign initials = initials | append: initial | append: '. ' -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign initials_stripped = initials | strip -%}
        {%- assign author_display = author_last_name | append: ', ' | append: initials_stripped -%}
        {%- assign first_initial = '' -%}
        {%- for part in first_parts -%}
          {%- assign cleaned_part = part | strip -%}
          {%- if cleaned_part != '' and first_initial == '' -%}
            {%- assign first_initial = cleaned_part | slice: 0, 1 | upcase | append: '.' -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign author_short = author_last_name | append: ', ' | append: first_initial -%}
        {%- assign is_corresponding = false -%}
        {%- assign is_cofirst = false -%}
        {% assign corr_norm = entry.corresponding | default: '' | downcase | remove_accents %}
        {% assign cofirst_norm = entry.cofirst | default: '' | downcase | remove_accents %}
        {% assign author_display_norm = author_display | downcase | remove_accents %}
        {% assign author_short_norm = author_short | downcase | remove_accents %}
        {% if corr_norm contains author_display_norm or corr_norm contains author_short_norm %}
          {%- assign is_corresponding = true -%}
        {% endif %}
        {% if cofirst_norm contains author_display_norm or cofirst_norm contains author_short_norm %}
          {%- assign is_cofirst = true -%}
        {% endif %}
        {% if author_last_name == 'Shekhar' and initials_stripped == 'K.' %}
          <strong>{{ author_display }}</strong>{% if is_cofirst %}<sup>*</sup>{% endif %}{% if is_corresponding %}<sup>&#8225;</sup>{% endif %}
        {% else %}
          {{ author_display }}{% if is_cofirst %}<sup>*</sup>{% endif %}{% if is_corresponding %}<sup>&#8225;</sup>{% endif %}
        {% endif %}
        {% unless forloop.last %}; {% endunless %}
      {% endfor %}
    </div>

    <!-- Journal/Book title and date -->
    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}
    {% if entry.type == 'article' %}
      {% capture entrytype %}<strong><em>{{entry.journal}}</em></strong>{% endcapture %}
    {% elsif proceedings contains entry.type %}
      {% capture entrytype %}<strong><em>In {{entry.booktitle}}</em></strong> {% endcapture %}
    {% elsif thesis contains entry.type %}
      {% capture entrytype %}<strong><em>{{entry.school}}</em></strong> {% endcapture %}
    {% else %}
      {% capture entrytype %}{% endcapture %}
    {% endif %}
    {% if entry.month %}
      {% capture entrymonth %}{{ " " }}{{ entry.month | capitalize }}{% endcapture %}
    {% endif %}
    {% if entry.year %}
      {% capture entryyear %}{{ " " }}{{entry.year}}{% endcapture %}
    {% endif %}
    {% assign entrytype_text = entrytype | strip_html | strip %}
    {% capture periodical %}{{ entrytype }}{% if entrytype_text != "" and entryyear != "" %}, {% endif %}{{ entrymonth }}{{ entryyear }}{% endcapture %}
    <div class="periodical">
      {{ periodical | strip }}
    </div>
    {% assign arxiv_id = '' %}
    {% if entry.arxiv %}
      {% assign arxiv_id = entry.arxiv %}
    {% elsif entry.eprint %}
      {% assign arxiv_id = entry.eprint %}
    {% elsif entry.html and entry.html contains 'arxiv.org/abs/' %}
      {% assign arxiv_id = entry.html | split: 'arxiv.org/abs/' | last | split: '?' | first %}
    {% endif %}
    {% if arxiv_id != '' %}
      <div class="periodical arxiv-meta">
        arXiv: {{ arxiv_id }} -
        <a href="https://arxiv.org/abs/{{ arxiv_id }}" target="_blank" rel="noopener noreferrer">arXiv preprint</a>
      </div>
    {% endif %}
    <div class="periodical">
      {{ entry.note | strip }}
    </div>

    <!-- Links/Buttons -->
    <div class="links">
      {% if entry.pdf %}
        {% if entry.pdf contains '://' %}
          <a href="{{ entry.pdf }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
        {% else %}
          <a href="{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
        {% endif %}
      {% endif %}
      <span
        class="oa-citation"
        data-title="{{ entry.title | escape_once }}"
        data-doi="{{ entry.doi | default: '' | escape_once }}"
        data-html="{{ entry.html | default: '' | escape_once }}"
      >citations ...</span>
    </div>
    {% if site.enable_publication_badges %}
      {% assign entry_has_altmetric_badge = entry.altmetric or entry.doi or  entry.eprint or entry.pmid or entry.isbn %}
      {% assign entry_has_dimensions_badge = entry.dimensions or entry.doi or entry.pmid %}
      {% if entry_has_altmetric_badge or entry_has_dimensions_badge %}
        <div class="badges">
          {% if site.enable_publication_badges.altmetric and entry_has_altmetric_badge %}
            <span
              class="altmetric-embed"
              data-hide-no-mentions="true"
              data-hide-less-than="15"
              data-badge-type="2"
              data-badge-popover="right"
              {% if entry.eprint %}
                data-arxiv-id="{{ entry.eprint }}"
              {% elsif entry.doi %}
                data-doi="{{ entry.doi }}"
              {% elsif entry.altmetric %}
                data-altmetric-id="{{ entry.altmetric }}"
              {% elsif entry.pmid %}
                data-pmid="{{ entry.pmid }}"
              {% elsif entry.isbn %}
                data-isbn="{{ entry.isbn }}"
              {% endif %}
            ></span>
          {% endif %}
          {% if site.enable_publication_badges.dimensions and entry_has_dimensions_badge %}
            <span
              class="__dimensions_badge_embed__"
              {% if entry.doi %}
                data-doi="{{ entry.doi }}"
              {% else %}
                data-pmid="{{ entry.pmid }}"
              {% else %}
                data-id="{{ entry.dimensions }}"
              {% endif %}
              data-hide-zero-citations="true"
              data-style="small_rectangle"
              data-legend="hover-right"
              style="margin-bottom: 3px;"
            ></span>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    {% if entry.abstract %}
      <!-- Hidden abstract block -->
      <div class="abstract hidden">
        <p>{{ entry.abstract }}</p>
      </div>
    {% endif %}

    {% if entry.video %}
      <!-- Hidden video block -->
      <div class="abstract hidden">
        <div style="text-align: center;">{% include video.liquid path=entry.video class="img-fluid rounded z-depth-1" controls=true %}</div>
      </div>
    {% endif %}
  </div>
</div>
